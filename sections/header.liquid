{% comment %}
  ==========================================================
  ATHLON PREMIUM HEADER — FINAL FIXED VERSION
  Clean UI / Correct Icons / Stable Mobile
  ==========================================================
{% endcomment %}

<header class="athlon-header" role="banner">

  <div class="athlon-header__inner">

    <!-- LOGO -->
    <a href="{{ routes.root_url }}" class="athlon-logo">

      {% if section.settings.logo != blank %}
        <img
          src="{{ section.settings.logo | image_url: width: 120 }}"
          alt="{{ shop.name }}"
          class="athlon-logo__img"
          loading="eager"
          width="36"
          height="36"
        >
      {% else %}
        <img
          src="{{ 'athlon-logo.png' | asset_url }}"
          alt="{{ shop.name }}"
          class="athlon-logo__img"
          loading="eager"
          width="36"
          height="36"
        >
      {% endif %}

      <span class="athlon-logo__text">
        {{ section.settings.logo_text | default: shop.name }}
      </span>

    </a>

    <!-- DESKTOP NAV -->
    <nav class="athlon-nav">

      <a href="{{ routes.all_products_collection_url }}" class="athlon-nav__link">
        Loja
      </a>

      <a href="/pages/manifesto" class="athlon-nav__link">
        Manifesto
      </a>

      <a href="/pages/descontos" class="athlon-nav__link">
        Descontos
      </a>

      <a href="/pages/contato" class="athlon-nav__link">
        Contato
      </a>

    </nav>

    <!-- ACTIONS -->
    <div class="athlon-actions">

      <!-- SEARCH -->
      <a
        href="{{ routes.search_url }}"
        class="athlon-btn"
        aria-label="Buscar"
      >
        <svg viewBox="0 0 24 24" fill="none">
          <circle cx="11" cy="11" r="7"></circle>
          <path d="M20 20L17 17"></path>
        </svg>
      </a>

      <!-- ACCOUNT -->
      <a
        href="{{ routes.account_url }}"
        class="athlon-btn"
        aria-label="Conta"
      >
        <svg viewBox="0 0 24 24" fill="none">
          <circle cx="12" cy="8" r="4"></circle>
          <path d="M4 20C4 16.5 7 14 12 14C17 14 20 16.5 20 20"></path>
        </svg>
      </a>

      <!-- CART -->
      <button
        type="button"
        class="athlon-btn athlon-cart"
        aria-label="Carrinho"
        data-cart-open
      >

        <svg viewBox="0 0 24 24" fill="none">
          <path d="M6 7H18L17 18H7L6 7Z"></path>
          <path d="M9 7V5C9 3.8 10 3 12 3C14 3 15 3.8 15 5V7"></path>
        </svg>

        <span
          class="athlon-cart__badge"
          data-cart-count
          style="display:none;"
        >
          0
        </span>

      </button>

      <!-- MOBILE MENU -->
      <button
        type="button"
        class="athlon-btn athlon-mobile-toggle"
        id="athlon-mobile-toggle-{{ section.id }}"
        aria-label="Menu"
      >

        <svg class="icon-menu" viewBox="0 0 24 24" fill="none">
          <path d="M4 7H20"></path>
          <path d="M4 12H20"></path>
          <path d="M4 17H20"></path>
        </svg>

        <svg class="icon-close" viewBox="0 0 24 24" fill="none">
          <path d="M6 6L18 18"></path>
          <path d="M18 6L6 18"></path>
        </svg>

      </button>

    </div>

  </div>

  <!-- MOBILE NAV -->
  <div
    class="athlon-mobile-nav"
    id="athlon-mobile-nav-{{ section.id }}"
  >

    <a href="{{ routes.all_products_collection_url }}">
      Loja
    </a>

    <a href="/pages/manifesto">
      Manifesto
    </a>

    <a href="/pages/descontos">
      Descontos
    </a>

    <a href="/pages/contato">
      Contato
    </a>

  </div>

</header>

<style>

  /* ==========================================================
     RESET
  ========================================================== */

  #shopify-section-{{ section.id }} * {
    box-sizing: border-box;
  }

  /* ==========================================================
     HEADER
  ========================================================== */

  #shopify-section-{{ section.id }} {
    position: fixed;
    top: 30px;
    left: 0;
    width: 100%;
    z-index: 9999;
  }

  #shopify-section-{{ section.id }} .athlon-header {

    width: 100%;

    background: transparent;

    transition:
      background .35s ease,
      backdrop-filter .35s ease,
      border-color .35s ease;

    border-bottom: 1px solid transparent;
  }

  #shopify-section-{{ section.id }} .athlon-header.is-scrolled {

    background: rgba(8,8,8,.82);

    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);

    border-bottom: 1px solid rgba(255,255,255,.06);

    box-shadow:
      0 10px 30px rgba(0,0,0,.18);
  }

  /* ==========================================================
     INNER
  ========================================================== */

  #shopify-section-{{ section.id }} .athlon-header__inner {

    max-width: 1440px;

    margin: 0 auto;

    height: 78px;

    padding: 0 28px;

    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  /* ==========================================================
     LOGO
  ========================================================== */

  #shopify-section-{{ section.id }} .athlon-logo {

    display: flex;
    align-items: center;
    gap: 12px;

    text-decoration: none;
  }

  #shopify-section-{{ section.id }} .athlon-logo__img {

    width: 36px;
    height: 36px;

    object-fit: contain;

    display: block;
  }

  #shopify-section-{{ section.id }} .athlon-logo__text {

    color: #fff;

    font-size: 17px;
    font-weight: 600;

    letter-spacing: -.02em;
  }

  /* ==========================================================
     NAV
  ========================================================== */

  #shopify-section-{{ section.id }} .athlon-nav {

    display: flex;
    align-items: center;
    gap: 32px;
  }

  #shopify-section-{{ section.id }} .athlon-nav__link {

    color: rgba(255,255,255,.82);

    text-decoration: none;

    font-size: 14px;
    font-weight: 500;

    transition: .25s ease;
  }

  #shopify-section-{{ section.id }} .athlon-nav__link:hover {
    color: #fff;
  }

  /* ==========================================================
     ACTIONS
  ========================================================== */

  #shopify-section-{{ section.id }} .athlon-actions {

    display: flex;
    align-items: center;
    gap: 10px;
  }

  /* ==========================================================
     BUTTONS
  ========================================================== */

  #shopify-section-{{ section.id }} .athlon-btn {

    width: 42px;
    height: 42px;

    min-width: 42px;
    min-height: 42px;

    border-radius: 999px;

    border: 1px solid rgba(255,255,255,.08);

    background: rgba(255,255,255,.03);

    display: flex;
    align-items: center;
    justify-content: center;

    color: #fff;

    cursor: pointer;

    transition:
      background .25s ease,
      border-color .25s ease,
      transform .25s ease;

    position: relative;

    padding: 0;

    overflow: hidden;
  }

  #shopify-section-{{ section.id }} .athlon-btn:hover {

    background: rgba(255,255,255,.08);

    border-color: rgba(255,255,255,.12);

    transform: translateY(-1px);
  }

  /* ==========================================================
     ICON FIX
  ========================================================== */

  #shopify-section-{{ section.id }} .athlon-btn svg {

    width: 17px !important;
    height: 17px !important;

    min-width: 17px;
    min-height: 17px;

    stroke: currentColor;
    stroke-width: 1.7;

    stroke-linecap: round;
    stroke-linejoin: round;

    overflow: visible;

    flex-shrink: 0;

    display: block;
  }

  /* ==========================================================
     CART BADGE
  ========================================================== */

  #shopify-section-{{ section.id }} .athlon-cart__badge {

    position: absolute;

    top: 4px;
    right: 4px;

    width: 16px;
    height: 16px;

    border-radius: 999px;

    background: #22c55e;

    color: #000;

    font-size: 10px;
    font-weight: 700;

    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* ==========================================================
     MOBILE MENU ICONS
  ========================================================== */

  #shopify-section-{{ section.id }} .icon-close {
    display: none;
  }

  /* ==========================================================
     MOBILE NAV
  ========================================================== */

  #shopify-section-{{ section.id }} .athlon-mobile-nav {

    position: absolute;

    top: 100%;
    left: 0;

    width: 100%;

    background: rgba(8,8,8,.98);

    backdrop-filter: blur(18px);

    padding: 18px 24px;

    display: flex;
    flex-direction: column;

    gap: 2px;

    opacity: 0;
    visibility: hidden;

    transform: translateY(-10px);

    transition: .3s ease;

    pointer-events: none;
  }

  #shopify-section-{{ section.id }} .athlon-mobile-nav.is-active {

    opacity: 1;
    visibility: visible;

    transform: translateY(0);

    pointer-events: auto;
  }

  #shopify-section-{{ section.id }} .athlon-mobile-nav a {

    color: #fff;

    text-decoration: none;

    padding: 14px 0;

    border-bottom: 1px solid rgba(255,255,255,.06);

    font-size: 15px;
  }

  /* ==========================================================
     RESPONSIVE
  ========================================================== */

  #shopify-section-{{ section.id }} .athlon-mobile-toggle {
    display: none;
  }

  @media screen and (max-width: 990px) {

    #shopify-section-{{ section.id }} .athlon-header__inner {

      height: 72px;

      padding: 0 18px;
    }

    #shopify-section-{{ section.id }} .athlon-nav {
      display: none;
    }

    #shopify-section-{{ section.id }} .athlon-mobile-toggle {
      display: flex;
    }

    #shopify-section-{{ section.id }} .athlon-logo__text {
      font-size: 15px;
    }

    #shopify-section-{{ section.id }} .athlon-actions {
      gap: 8px;
    }

    #shopify-section-{{ section.id }} .athlon-btn {

      width: 40px;
      height: 40px;

      min-width: 40px;
      min-height: 40px;
    }

    #shopify-section-{{ section.id }} .athlon-btn svg {

      width: 16px !important;
      height: 16px !important;
    }
  }

</style>

<script>

  (() => {

    const section =
      document.getElementById('shopify-section-{{ section.id }}');

    if (!section) return;

    const header =
      section.querySelector('.athlon-header');

    const menuBtn =
      document.getElementById('athlon-mobile-toggle-{{ section.id }}');

    const mobileNav =
      document.getElementById('athlon-mobile-nav-{{ section.id }}');

    /* =========================================
       SCROLL EFFECT
    ========================================== */

    const updateHeader = () => {

      if (window.scrollY > 30) {
        header.classList.add('is-scrolled');
      } else {
        header.classList.remove('is-scrolled');
      }
    };

    updateHeader();

    window.addEventListener(
      'scroll',
      updateHeader,
      { passive: true }
    );

    /* =========================================
       MOBILE MENU
    ========================================== */

    if (menuBtn && mobileNav) {

      menuBtn.addEventListener('click', () => {

        mobileNav.classList.toggle('is-active');

        const isActive =
          mobileNav.classList.contains('is-active');

        const menuIcon =
          menuBtn.querySelector('.icon-menu');

        const closeIcon =
          menuBtn.querySelector('.icon-close');

        if (menuIcon && closeIcon) {

          menuIcon.style.display =
            isActive ? 'none' : 'block';

          closeIcon.style.display =
            isActive ? 'block' : 'none';
        }
      });
    }

  })();

</script>

{% schema %}
{
  "name": "Athlon Header",
  "tag": "section",
  "class": "athlon-header-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "text",
      "id": "logo_text",
      "label": "Texto da logo",
      "default": "Athlon"
    }
  ],
  "presets": [
    {
      "name": "Athlon Header"
    }
  ]
}
{% endschema %}