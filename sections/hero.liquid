{% liquid
  assign media_count = 0
  assign media_count_mobile = 0
  assign fallback_to_desktop = false
  assign media_1 = 'none'
  assign media_2 = 'none'
  assign media_1_mobile = 'none'
  assign media_2_mobile = 'none'
  assign has_only_video = false
  assign has_only_video_mobile = false

  if section.settings.image_1 != blank and section.settings.media_type_1 == 'image'
    assign media_1 = 'image'
    assign media_count = media_count | plus: 1
  endif
  if section.settings.video_1 != blank and section.settings.media_type_1 == 'video'
    assign media_1 = 'video'
    assign media_count = media_count | plus: 1
  endif
  if section.settings.image_2 != blank and section.settings.media_type_2 == 'image'
    assign media_2 = 'image'
    assign media_count = media_count | plus: 1
  endif
  if section.settings.video_2 != blank and section.settings.media_type_2 == 'video'
    assign media_2 = 'video'
    assign media_count = media_count | plus: 1
  endif

  if section.settings.custom_mobile_media
    if section.settings.image_1_mobile != blank and section.settings.media_type_1_mobile == 'image'
      assign media_1_mobile = 'image'
      assign media_count_mobile = media_count_mobile | plus: 1
    endif
    if section.settings.video_1_mobile != blank and section.settings.media_type_1_mobile == 'video'
      assign media_1_mobile = 'video'
      assign media_count_mobile = media_count_mobile | plus: 1
    endif
    if section.settings.image_2_mobile != blank and section.settings.media_type_2_mobile == 'image'
      assign media_2_mobile = 'image'
      assign media_count_mobile = media_count_mobile | plus: 1
    endif
    if section.settings.video_2_mobile != blank and section.settings.media_type_2_mobile == 'video'
      assign media_2_mobile = 'video'
      assign media_count_mobile = media_count_mobile | plus: 1
    endif
  endif

  if media_count > 0 and media_1 != 'image' and media_2 != 'image'
    assign has_only_video = true
  endif
  if media_count > 0 and media_count_mobile > 0 and media_1_mobile != 'image' and media_2_mobile != 'image'
    assign has_only_video_mobile = true
  endif

  assign media_wrapper_desktop_class = 'hero__media-wrapper hero__media-wrapper--desktop'
  assign media_wrapper_mobile_class = 'hero__media-wrapper hero__media-wrapper--mobile'
  
  if section.settings.custom_mobile_media == false or section.settings.custom_mobile_media == true and media_count_mobile == 0
    assign media_wrapper_desktop_class = media_wrapper_desktop_class | append: ' hero__media-wrapper--mobile'
  endif

  if media_1 == 'image' and media_2 == 'image'
    assign media_width_desktop = '50vw'
  else
    assign media_width_desktop = '100vw'
  endif

  if section.settings.custom_mobile_media == false or media_count_mobile == 0 or media_count == 0
    assign media_count_mobile = media_count
    assign fallback_to_desktop = true
  endif

  if fallback_to_desktop
    assign media_width_mobile = media_width_desktop
  elsif section.settings.stack_media_on_mobile or media_1_mobile != 'image' or media_2_mobile != 'image'
    assign media_width_mobile = '100vw'
  else
    assign media_width_mobile = '50vw'
  endif

  assign sizes = '(min-width: 750px) ' | append: media_width_desktop | append: ', ' | append: media_width_mobile
  assign widths = '832, 1200, 1600, 1920, 2560, 3840'
  assign sizes_mobile = media_width_mobile
  assign mobile_widths = '416, 600, 800, 1200, 1600'
  assign mobile_widths_array = mobile_widths | split: ', '
  assign fetch_priority = 'auto'

  if section.index == 1
    assign fetch_priority = 'high'
  endif
%}

{% capture media_slot_1 %}
  {%- if media_1 == 'image' and media_1_mobile == 'image' -%}
    <picture class="hero__media">
      <source media="(max-width: 749px)" srcset="{%- for mobile_width in mobile_widths_array -%}{{ section.settings.image_1_mobile | image_url: width: mobile_width }} {{ mobile_width }}w{% unless forloop.last %},{% endunless %}{%- endfor -%}" sizes="{{ sizes_mobile }}" width="{{ section.settings.image_1_mobile.width }}" height="{{ section.settings.image_1_mobile.height }}">
      {{ section.settings.image_1 | image_url: width: 3840 | image_tag: width: section.settings.image_1.width, widths: widths, height: section.settings.image_1.height, alt: section.settings.image_1.alt, class: 'hero__media', sizes: sizes, fetchpriority: fetch_priority }}
    </picture>
  {%- elsif media_1 == 'image' -%}
    <div class="{{ media_wrapper_desktop_class }}">
      {{ section.settings.image_1 | image_url: width: 3840 | image_tag: width: section.settings.image_1.width, widths: widths, height: section.settings.image_1.height, alt: section.settings.image_1.alt, class: 'hero__media', sizes: sizes, fetchpriority: fetch_priority }}
    </div>
  {%- endif -%}

  {%- if media_1 == 'video' -%}
    <div class="{{ media_wrapper_desktop_class }}">
      {{ section.settings.video_1 | video_tag: poster: nil, autoplay: true, loop: true, controls: false, muted: true, class: 'hero__media' }}
    </div>
  {%- endif -%}

  {%- if media_count > 0 and media_count_mobile > 0 -%}
    {%- if media_1_mobile == 'image' and media_1 != 'image' -%}
      <div class="{{ media_wrapper_mobile_class }}">
        {{ section.settings.image_1_mobile | image_url: width: 1600 | image_tag: width: section.settings.image_1_mobile.width, widths: mobile_widths, height: section.settings.image_1_mobile.height, alt: section.settings.image_1_mobile.alt, class: 'hero__media', sizes: sizes_mobile, fetchpriority: fetch_priority }}
      </div>
    {%- endif -%}

    {%- if media_1_mobile == 'video' -%}
      <div class="{{ media_wrapper_mobile_class }}">
        {{ section.settings.video_1_mobile | video_tag: poster: nil, autoplay: true, loop: true, controls: false, muted: true, class: 'hero__media' }}
      </div>
    {%- endif -%}
  {%- endif -%}
{% endcapture %}

{% capture media_slot_2 %}
  {%- if media_2 == 'image' and media_2_mobile == 'image' -%}
    <picture class="hero__media">
      <source media="(max-width: 749px)" srcset="{%- for mobile_width in mobile_widths_array -%}{{ section.settings.image_2_mobile | image_url: width: mobile_width }} {{ mobile_width }}w{% unless forloop.last%},{% endunless %}{%- endfor -%}" sizes="{{ sizes_mobile }}" width="{{ section.settings.image_2_mobile.width }}" height="{{ section.settings.image_2_mobile.height }}">
      {{ section.settings.image_2 | image_url: width: 3840 | image_tag: width: section.settings.image_2.width, widths: widths, height: section.settings.image_2.height, alt: section.settings.image_2.alt, class: 'hero__media', sizes: sizes, fetchpriority: fetch_priority }}
    </picture>
  {%- elsif media_2 == 'image' -%}
    <div class="{{ media_wrapper_desktop_class }}">
      {{ section.settings.image_2 | image_url: width: 3840 | image_tag: width: section.settings.image_2.width, widths: widths, height: section.settings.image_2.height, alt: section.settings.image_2.alt, class: 'hero__media', sizes: sizes, fetchpriority: fetch_priority }}
    </div>
  {%- endif -%}

  {%- if media_2 == 'video' -%}
    <div class="{{ media_wrapper_desktop_class }}">
      {{ section.settings.video_2 | video_tag: poster: nil, autoplay: true, loop: true, controls: false, muted: true, class: 'hero__media' }}
    </div>
  {%- endif -%}

  {%- if media_count > 0 and media_count_mobile > 0 -%}
    {%- if media_2_mobile == 'image' and media_2 != 'image' -%}
      <div class="{{ media_wrapper_mobile_class }}">
        {{ section.settings.image_2_mobile | image_url: width: 1600 | image_tag: width: section.settings.image_2_mobile.width, widths: mobile_widths, height: section.settings.image_2_mobile.height, alt: section.settings.image_2_mobile.alt, class: 'hero__media', sizes: sizes_mobile, fetchpriority: fetch_priority }}
      </div>
    {%- endif -%}

    {%- if media_2_mobile == 'video' -%}
      <div class="{{ media_wrapper_mobile_class }}">
        {{ section.settings.video_2_mobile | video_tag: poster: nil, autoplay: true, loop: true, controls: false, muted: true, class: 'hero__media' }}
      </div>
    {%- endif -%}
  {%- endif -%}
{% endcapture %}

{% capture media %}
  {{ media_slot_1 }}
  {{ media_slot_2 }}
  {% if media_count == 0 %}
    {{ 'hero-apparel-1' | placeholder_svg_tag: 'hero__media placeholder-svg' }}
  {%- endif -%}
{% endcapture %}

<div
  id="Hero-{{ section.id }}"
  class="hero color-{{ section.settings.color_scheme }} {% if section.settings.enable_grain %}grain{% endif %} {% if section.settings.stack_media_on_mobile %} hero--stack-mobile{% endif %}"
  style="
    --hero-accent: {{ section.settings.accent_color }};
    {% if section.settings.section_height == 'custom' %}
      --hero-min-height: {{ section.settings.section_height_custom }}svh;
    {% elsif section.settings.section_height == 'full-screen' %}
       --hero-min-height: 100svh;
    {% else %}
      --hero-min-height: 80svh;
    {% endif %}
  "
>
  <div class="hero__container {% if section.settings.section_width == 'page-width' %}page-width{% endif %}">
    
    {%- if section.settings.link != blank -%}
      <a href="{{ section.settings.link }}" class="hero__link" {% if section.settings.open_in_new_tab %}target="_blank" rel="noopener"{% endif %}></a>
    {%- endif -%}
    
    <div class="hero__media-grid" style="--hero-media-count: {{ media_count | default: 1 }}; --hero-media-count-mobile: {{ media_count_mobile | default: 1 }};">
      {%- if section.settings.toggle_overlay -%}
        <div class="hero__overlay" style="background: {% if section.settings.overlay_style == 'solid' %}{{ section.settings.overlay_color }}{% else %}linear-gradient({{ section.settings.gradient_direction }}, {{ section.settings.overlay_color }}, transparent){% endif %};"></div>
      {%- endif -%}
      {{ media }}
      
      {%- if section.settings.show_gradients -%}
        <div class="hero-bg__grad-lr"></div>
        <div class="hero-bg__grad-bt"></div>
      {%- endif -%}
    </div>

    <div class="hero__content-wrapper layout-panel-flex layout-panel-flex--{{ section.settings.content_direction }} {% if section.settings.vertical_on_mobile %}mobile-column{% endif %}"
         style="justify-content: {{ section.settings.horizontal_alignment_flex_direction_column }}; align-items: {{ section.settings.vertical_alignment_flex_direction_column }};">
      
      <div class="hero-inner">
        {%- for block in section.blocks -%}
          {%- case block.type -%}
            
            {%- when 'eyebrow' -%}
              <div class="hero-eyebrow animate-fade-in" {{ block.shopify_attributes }}>
                <span class="hero-eyebrow__line" aria-hidden="true"></span>
                <span class="hero-eyebrow__text">{{ block.settings.text }}</span>
              </div>

            {%- when 'heading' -%}
              <h1 class="hero-h1 animate-fade-up" {{ block.shopify_attributes }}>
                {{ block.settings.heading }}
                {%- if block.settings.heading_muted != blank -%}
                  <br><span class="hero-h1__muted">{{ block.settings.heading_muted }}</span><span class="hero-h1__dot">.</span>
                {%- endif -%}
              </h1>

            {%- when 'subtext' -%}
              <p class="hero-sub animate-fade-up" style="animation-delay:120ms;" {{ block.shopify_attributes }}>
                {{ block.settings.subtext }}
              </p>

            {%- when 'buttons' -%}
              <div class="hero-ctas animate-fade-up" style="animation-delay:240ms;" {{ block.shopify_attributes }}>
                {%- if block.settings.cta_primary_label != blank -%}
                  <a href="{{ block.settings.cta_primary_url }}" class="btn btn--primary">
                    {{ block.settings.cta_primary_label }}
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>
                  </a>
                {%- endif -%}
                {%- if block.settings.cta_secondary_label != blank -%}
                  <a href="{{ block.settings.cta_secondary_url }}" class="btn btn--ghost">
                    {{ block.settings.cta_secondary_label }}
                  </a>
                {%- endif -%}
              </div>

            {%- when 'pillar' -%}
              {%- if forloop.first or section.blocks[forloop.index0].type != 'pillar' -%}
                <div class="hero-pillars animate-fade-up" style="animation-delay:360ms;">
              {%- endif -%}
              
              <div class="hero-pillar" {{ block.shopify_attributes }}>
                <div class="hero-pillar__icon" aria-hidden="true">
                  {%- case block.settings.icon -%}
                    {%- when 'beaker' -%}
                      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4.5 3h15"/><path d="M6 3v16a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2V3"/><path d="M6 14h12"/></svg>
                    {%- when 'shield-check' -%}
                      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>
                    {%- when 'leaf' -%}
                      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10Z"/><path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"/></svg>
                  {%- endcase -%}
                </div>
                <div class="hero-pillar__text-group">
                  <div class="hero-pillar__k">{{ block.settings.key }}</div>
                  <div class="hero-pillar__v">{{ block.settings.value }}</div>
                </div>
              </div>

              {%- if forloop.last or section.blocks[forloop.index].type != 'pillar' -%}
                </div>
              {%- endif -%}

          {%- endcase -%}
        {%- endfor -%}
      </div>
    </div>
    
    {%- for block in section.blocks -%}
      {%- if block.type == 'marquee' -%}
        <div class="hero-marquee" aria-hidden="true" {{ block.shopify_attributes }}>
          <div class="hero-marquee__track">
            {%- assign marquee_items = block.settings.text | split: '|' -%}
            {%- for i in (1..2) -%}
              <div class="hero-marquee__set" {%- if i == 2 %} aria-hidden="true"{% endif %}>
                {%- for item in marquee_items -%}
                  <span>{{ item }}</span>
                  <span class="hero-marquee__dot"></span>
                {%- endfor -%}
              </div>
            {%- endfor -%}
          </div>
        </div>
      {%- endif -%}
    {%- endfor -%}

  </div>
</div>

{% stylesheet %}
  .hero {
    position: relative;
    min-height: var(--hero-min-height);
    display: flex;
    flex-direction: column;
    font-family: inherit;
    padding-top: 78px; 
  }

  @media screen and (max-width: 990px) {
    .hero {
      padding-top: 72px; 
    }
  }

  .hero__container {
    position: relative;
    overflow: hidden;
    flex-grow: 1;
    display: flex;
    min-height: inherit;
    z-index: 1;
  }

  .hero__media-grid {
    position: absolute;
    inset: 0;
    display: grid;
    grid-template-columns: repeat(var(--hero-media-count, 1), 1fr);
    z-index: -1;
  }

  .hero__media {
    height: 100%;
    width: 100%;
    object-fit: cover;
    object-position: center center;
    position: relative;
  }

  .hero__media-wrapper--mobile { display: none; }
  .hero__media-wrapper--desktop { display: block; height: 100%; }

  @media screen and (max-width: 749px) {
    .hero__media-wrapper--desktop { display: none; }
    .hero__media-wrapper--mobile { display: block; height: 100%; }
    .hero__media-grid { grid-template-columns: repeat(var(--hero-media-count-mobile, 1), 1fr); }
    .hero--stack-mobile .hero__media-grid {
      grid-template-columns: 1fr;
      grid-template-rows: repeat(var(--hero-media-count-mobile, 1), calc(100% / var(--hero-media-count-mobile, 1)));
    }
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
  }

  .hero__link {
    position: absolute;
    inset: 0;
    z-index: 2;
  }

  .hero-bg__grad-lr {
    position: absolute; inset: 0;
    background: linear-gradient(to right, rgba(0,0,0,0.8) 0%, transparent 60%);
    z-index: 2; pointer-events: none;
  }
  .hero-bg__grad-bt {
    position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.9) 0%, transparent 50%);
    z-index: 2; pointer-events: none;
  }

  .grain::after {
    content: "";
    position: absolute; inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
    opacity: 0.05;
    pointer-events: none;
    z-index: 10;
  }

  .hero__content-wrapper {
    position: relative;
    z-index: 5;
    display: flex;
    width: 100%;
    align-items: flex-end;
    padding: clamp(5rem, 12vw, 8rem) clamp(1.25rem, 4vw, 4rem) 2rem;
    pointer-events: none;
    flex-grow: 1;
  }
  
  @media screen and (max-width: 749px) {
    .hero__content-wrapper {
      /* No mobile: margem lateral ajustada para não apertar demais o texto */
      padding: 5rem 2.5rem 4rem 2.5rem;
    }
  }

  .hero-inner {
    max-width: 720px;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    align-items: flex-start;
    text-align: left;
    pointer-events: auto;
    padding: clamp(1rem, 2.4vw, 1.35rem);
    border: 1px solid color-mix(in srgb, var(--color-foreground) 14%, transparent);
    border-radius: 28px;
    background: linear-gradient(145deg, color-mix(in srgb, var(--color-background) 68%, transparent), color-mix(in srgb, var(--color-background) 34%, transparent));
    box-shadow: 0 18px 40px rgba(0, 0, 0, 0.28);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }

  /* --- TYPOGRAPHY & COLORS MATCHING THE IMAGE --- */

  .hero-eyebrow {
    display: flex; align-items: center; gap: 1rem;
    font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.15em;
    color: var(--hero-accent); 
    font-weight: 600;
  }
  .hero-eyebrow__line { width: 40px; height: 1px; background: currentColor; }

  .hero-h1 {
    font-size: clamp(3rem, 6vw, 5rem);
    line-height: 1.02;
    margin: 0;
    font-weight: 800;
    color: var(--color-foreground);
    letter-spacing: -0.03em;
  }
  .hero-h1__muted {
    color: color-mix(in srgb, var(--color-foreground) 55%, transparent);
    font-style: normal;
  }
  .hero-h1__dot { color: var(--hero-accent); }

  .hero-sub {
    font-size: clamp(1rem, 1.5vw, 1.1rem);
    line-height: 1.65;
    color: color-mix(in srgb, var(--color-foreground) 72%, transparent);
    margin: 0;
    max-width: 90%;
  }

  /* --- BUTTONS --- */
  .hero-ctas {
    display: flex; 
    gap: 1rem; 
    flex-wrap: wrap; 
    margin-top: 1rem;
    justify-content: flex-start;
  }
  
  .btn {
    display: inline-flex; align-items: center; justify-content: center; gap: 0.5rem;
    padding: 1rem 2rem; font-weight: 600; text-decoration: none;
    border-radius: 50px;
    transition: all 0.3s ease;
    width: max-content;
    font-size: 0.95rem;
  }
  
  .btn--primary {
    background: var(--hero-accent);
    color: #06111A;
    border: 1px solid transparent;
    box-shadow: 0 10px 24px color-mix(in srgb, var(--hero-accent) 25%, transparent);
  }
  .btn--primary:hover { 
    filter: brightness(1.1); 
    transform: translateY(-2px); 
  }
  
  .btn--ghost {
    background: color-mix(in srgb, var(--color-background) 18%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-foreground) 18%, transparent);
    color: var(--color-foreground);
  }
  .btn--ghost:hover { 
    background: rgba(255, 255, 255, 0.1); 
  }

  /* --- PILLARS --- */
  .hero-pillars {
    display: flex; flex-direction: column; gap: 1.5rem; margin-top: 3rem;
    width: 100%;
  }
  @media(min-width: 768px) {
    .hero-pillars { flex-direction: row; gap: 3rem; }
  }
  
  .hero-pillar { display: flex; align-items: flex-start; gap: 0.75rem; }
  
  .hero-pillar__icon { 
    color: var(--hero-accent); 
    flex-shrink: 0;
    margin-top: 2px;
  }
  
  .hero-pillar__text-group {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .hero-pillar__k { 
    font-weight: 600; 
    font-size: 0.95rem; 
    color: #ffffff;
  }
  
  .hero-pillar__v { 
    font-size: 0.65rem; 
    color: rgba(255, 255, 255, 0.5); 
    text-transform: uppercase; 
    letter-spacing: 0.05em;
    line-height: 1.4;
  }

  /* --- MARQUEE --- */
  .hero-marquee {
    position: absolute; bottom: 0; left: 0; right: 0;
    border-top: 1px solid rgba(255,255,255,0.05);
    background: rgba(0,0,0,0.3); backdrop-filter: blur(8px);
    overflow: hidden; padding: 0.8rem 0; z-index: 5;
  }
  .hero-marquee__track {
    display: flex; width: max-content;
    animation: marquee 30s linear infinite;
  }
  .hero-marquee__set {
    display: flex; align-items: center; padding-right: 3rem; gap: 3rem;
  }
  .hero-marquee__set span {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(255, 255, 255, 0.6);
  }
  .hero-marquee__dot { width: 4px; height: 4px; border-radius: 50%; background: var(--hero-accent); opacity: 1; }
  
  @keyframes marquee { 0% { transform: translateX(0); } 100% { transform: translateX(-50%); } }

  /* Animations */
  .animate-fade-in { animation: fadeIn 0.8s ease forwards; }
  .animate-fade-up { opacity: 0; transform: translateY(20px); animation: fadeUp 0.8s ease forwards; }
  @keyframes fadeIn { to { opacity: 1; } }
  @keyframes fadeUp { to { opacity: 1; transform: translateY(0); } }

  .placeholder-svg { background-color: #111; color: #333; }
{% endstylesheet %}

{% schema %}
{
  "name": "Hero Personalizado",
  "tag": "section",
  "class": "hero-wrapper",
  "settings": [
    {
      "type": "header", "content": "Mídia 1"
    },
    {
      "type": "select", "id": "media_type_1", "label": "Tipo", "options": [{"value": "image", "label": "Imagem"}, {"value": "video", "label": "Vídeo"}], "default": "image"
    },
    {
      "type": "image_picker", "id": "image_1", "label": "Imagem 1"
