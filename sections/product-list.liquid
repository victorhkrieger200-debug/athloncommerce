{% liquid
  assign max_items = section.settings.max_products
%}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  data-testid="product-list"
  class="
    section
    section--{{ section.settings.section_width }}
    color-{{ section.settings.color_scheme }}
    section-resource-list
    spacing-style
    gap-style
    athlon-product-list
  "
  style="
    {% render 'spacing-style', settings: section.settings %}
    {% render 'gap-style', value: section.settings.gap %}
    --section-accent: {{ section.settings.accent_color | default: '#00e676' }};
  "
>
  <div class="section-resource-list__header">
    {%- content_for 'block', type: '_product-list-content', id: 'static-header' -%}
  </div>

  {% capture list_items %}
    {% if section.settings.collection != blank and shop.products_count != 0 %}
      {% paginate section.settings.collection.products by max_items %}
        {% for product in section.settings.collection.products limit: max_items %}
          <div
            class="resource-list__item"
          >
            {% # theme-check-disable UniqueStaticBlockId %}
              {% content_for 'block', type: '_product-card', id: 'static-product-card', closest.product: product %}
            {% # theme-check-enable UniqueStaticBlockId %}
          </div>

          {% unless forloop.last %}
            {% endunless %}
        {% endfor %}
      {% endpaginate %}
    {% else %}
      {% for i in (1..max_items) %}
        <div
          class="resource-list__item"
        >
          {% # theme-check-disable UniqueStaticBlockId %}
            {% content_for 'block', type: '_product-card', id: 'static-product-card', closest.product: null %}
          {% # theme-check-enable UniqueStaticBlockId %}
        </div>

        {% unless forloop.last %}
          {% endunless %}
      {% endfor %}
    {% endif %}
  {% endcapture %}

  {% liquid
    # Create an array from the list items to be used for different layout types
    assign list_items_array = list_items | strip | split: ''
  %}

  {% render 'resource-list',
    list_items: list_items,
    list_items_array: list_items_array,
    settings: section.settings,
    slide_count: max_items,
    content_type: 'products',
    test_id: 'resource-list-grid'
  %}

  <div
    class="section-resource-list__content"
    style="--horizontal-alignment: {{ section.settings.horizontal_alignment }};"
  >
    {%- content_for 'blocks' -%}
  </div>
</div>

<style>
  /* ==========================================================
     ATHLON PREMIUM PRODUCT LIST OVERRIDE
  ========================================================== */

  /* Forçar Background Escuro Unificado */
  #shopify-section-{{ section.id }},
  #shopify-section-{{ section.id }} .section-background,
  #shopify-section-{{ section.id }} .athlon-product-list {
    background-color: #050505 !important;
    background: #050505 !important;
  }

  /* Alinhamento de Margens Laterais com a Hero */
  #shopify-section-{{ section.id }} .section--page-width {
    padding-left: 4rem !important;
    padding-right: 4rem !important;
  }

  /* Estilização Avançada dos Cards de Produto Nativos */
  #shopify-section-{{ section.id }} .resource-list__item,
  #shopify-section-{{ section.id }} [data-block-type="_product-card"] {
    background-color: #0d0d0d !important; /* Caixa interna grafite escuro */
    border: 1px solid rgba(255, 255, 255, 0.05) !important;
    border-radius: 16px !important;
    overflow: hidden !important;
    padding: 12px !important;
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1), border-color 0.6s ease, box-shadow 0.6s ease !important;
  }

  /* Ajuste Fino nas Imagens e Galerias do Card */
  #shopify-section-{{ section.id }} [class*="gallery"],
  #shopify-section-{{ section.id }} [class*="media"],
  #shopify-section-{{ section.id }} img {
    border-radius: 12px !important; /* Arredondamento harmônico interno */
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1) !important;
  }

  /* Tipografia: Títulos dos Produtos */
  #shopify-section-{{ section.id }} [class*="product-title"] *,
  #shopify-section-{{ section.id }} [class*="title"] a {
    color: #ffffff !important;
    font-weight: 600 !important;
    letter-spacing: -0.01em !important;
    text-decoration: none !important;
  }

  /* Preços: Destaque Neon Premium */
  #shopify-section-{{ section.id }} .price,
  #shopify-section-{{ section.id }} [class*="price"] * {
    color: var(--section-accent) !important;
    font-weight: 700 !important;
    letter-spacing: 0.02em !important;
  }

  /* Trata preços antigos riscados (Sale mode) */
  #shopify-section-{{ section.id }} s,
  #shopify-section-{{ section.id }} [class*="compare"] {
    color: rgba(255, 255, 255, 0.3) !important;
    font-weight: 400 !important;
    font-size: 0.9em !important;
  }

  /* ========================================
     EFEITO INTERATIVO (HOVER UI/UX)
  ======================================== */
  #shopify-section-{{ section.id }} .resource-list__item:hover,
  #shopify-section-{{ section.id }} [data-block-type="_product-card"]:hover {
    transform: translateY(-8px) !important;
    border-color: rgba(0, 230, 118, 0.4) !important;
    box-shadow: 0 20px 40px rgba(0, 230, 118, 0.12) !important;
  }

  #shopify-section-{{ section.id }} .resource-list__item:hover img {
    transform: scale(1.04) !important; /* Zoom sutil na imagem do produto */
  }

  /* Controles e Setas do Carrossel de Produtos */
  #shopify-section-{{ section.id }} button.slider-button,
  #shopify-section-{{ section.id }} .carousel__navigation button {
    background-color: #111111 !important;
    border: 1px solid rgba(255, 255, 255, 0.15) !important;
    color: #ffffff !important;
    border-radius: 50% !important;
    width: 44px !important;
    height: 44px !important;
    transition: all 0.4s ease !important;
  }

  #shopify-section-{{ section.id }} button.slider-button:hover,
  #shopify-section-{{ section.id }} .carousel__navigation button:hover {
    border-color: var(--section-accent) !important;
    color: var(--section-accent) !important;
    background-color: rgba(0, 230, 118, 0.05) !important;
  }

  /* Responsividade de Margem Lateral */
  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .section--page-width {
      padding-left: 2.5rem !important;
      padding-right: 2.5rem !important;
    }
  }
</style>

